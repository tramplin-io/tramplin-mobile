# Tramplin Mobile Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For "eas build --platform android --profile preview --local":
#   - Option A: Ensure .env exists (postinstall copies this file if .env is missing).
#   - Option B: Preview profile in eas.json already sets EXPO_PUBLIC_* in "env", so local build gets them without .env.

# ── API ──
EXPO_PUBLIC_API_URL=https://develop-api.tramplin.io/api
EXPO_PUBLIC_REFERRALS_API_URL=https://referrals-api.tramplin.io/api

# ── Solana ──
# Network: devnet, testnet, mainnet-beta
EXPO_PUBLIC_SOLANA_NETWORK='mainnet-beta'
# Custom RPC endpoint (optional, uses default (devnet) public RPC if empty)
EXPO_PUBLIC_SOLANA_RPC_URL='https://theodora-ppq4tm-fast-mainnet.helius-rpc.com/'

# ── Solana Validator Vote Key ──
EXPO_PUBLIC_SOLANA_VALIDATOR_VOTE_KEY=TRAMp1Z9EXyWQQNwNjjoNvVksMUHKioVU7ky61yNsEq
EXPO_PUBLIC_SOLANA_PROGRAM_ID=3NJyzGWjSHP4hZvsqakodi7jAtbufwd52vn1ek6EzQ35


# ── App Identity ── 
#  As options to change default in src/constants/app-config.ts
# EXPO_PUBLIC_APP_NAME=Tramplin
# EXPO_PUBLIC_APP_URI=https://tramplin.io
# EXPO_PUBLIC_APP_ICON='/public/tramplin-logo.png'

# ── Sentry ──
EXPO_PUBLIC_SENTRY_DSN='https://d23bf865ed2b4a787871626a4c0c6760@o4509627651194880.ingest.de.sentry.io/4509627659321424'

# ── Telegram Bot Name ──
EXPO_PUBLIC_TELEGRAM_BOT_NAME=TramplinAppDevBot

# ── Charles Proxy (dev only) ──
# Set to true to trust user-installed CA (Charles) for HTTPS sniffing. Re-run prebuild after changing.
# EXPO_PUBLIC_ENABLE_CHARLES_PROXY=true
# ENABLE_CHARLES_PROXY=true
