# Tramplin Mobile Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── API ──
EXPO_PUBLIC_API_URL=https://api.example.com

# ── Solana ──
# Network: devnet, testnet, mainnet-beta
EXPO_PUBLIC_SOLANA_NETWORK=devnet
# Custom RPC endpoint (optional, uses default public RPC if empty)
EXPO_PUBLIC_SOLANA_RPC_URL='https://lb.drpc.org/solana-devnet/AikqCOD5x0xinaePzv2sbWSbkWVXNCwR8IPg2gG4MHGt'

# ── App Identity ──
EXPO_PUBLIC_APP_NAME=Tramplin
EXPO_PUBLIC_APP_URI=https://github.com/beeman/tramplin-mobile
